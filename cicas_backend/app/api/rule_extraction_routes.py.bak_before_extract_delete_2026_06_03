    后台执行提取任务

    这个函数在后台任务中运行，不会阻塞HTTP请求
    """
    global _extraction_in_progress

    # ========== 并发控制：检查是否已有该标准的提取任务在进行 ==========
    async with _extraction_lock:
        if request.standard_id in _extraction_in_progress:
            app_logger.warning(
                f"Extraction for standard {request.standard_id} already in progress. "
                f"Skipping duplicate request."
            )
            return  # 放弃此任务，避免并发

        # 标记此提取任务为进行中
        _extraction_in_progress.add(request.standard_id)

    try:
        # 创建新的数据库会话
        from app.core.database import SessionLocal
        db = SessionLocal()

        try:
            # ========== 第一步：删除该标准的旧规则（在提取前执行）==========
            try:
                app_logger.info(f"[Step 1] Deleting old rules for standard {request.standard_id}...")

                # 先获取要删除的规则ID
                from app.models.models import AdversarialFeedback
                from sqlalchemy import text
                rule_ids = [r.id for r in db.query(Rule.id).filter(Rule.standard_id == request.standard_id).all()]

                if rule_ids:
                    # 第一步：只删除 source_rule_id 指向当前标准的引用
                    # 不删除 target_rule_id 指向当前标准的引用（由其他文档指向）
                    # 这些引用会在后续的"更新未解析引用"阶段被更新
                    deleted_kg = db.execute(
                        text("""
                            DELETE FROM kg_relations
                            WHERE source_rule_id IN :rule_ids
                        """),
                        {'rule_ids': tuple(rule_ids)}
                    ).rowcount
                    app_logger.info(f"[Step 1] Deleted {deleted_kg} kg_relations records (source only)")

                    # 第二步：将 target_rule_id 指向被删除规则的引用标记为未解析
                    # 这些引用会在后续被重新解析
                    updated_to_unresolved = db.execute(
                        text("""
                            UPDATE kg_relations
                            SET target_rule_id = NULL,
                                is_uncertain = true,
                                confidence = 0.0,
                                reason = jsonb_set(
                                    COALESCE(reason, '{}'::jsonb),
                                    '{temporarily_unresolved}',
                                    'true'::jsonb
